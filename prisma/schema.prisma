generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum RoleStatus {
  ACTIVE
  INACTIVE
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  status          RoleStatus       @default(ACTIVE)
  isDeleted       Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  roleFeature     RoleFeature[]
  departmentHeads DepartmentHead[]
}

model RoleFeature {
  id     String @id @default(uuid())
  name   String
  index  Int
  path   String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
}

model Category {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  blogs     Blog[]
  projects  Project[]
  services  Service[]
}

model Blog {
  id          String   @id @default(uuid())
  title       String
  description String   @db.LongText
  categoryId  String
  categories  Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  thumbnail   String?  @db.LongText
  tags        Tag[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tag {
  id        String   @id @default(uuid())
  name      String
  blogId    String
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  subject   String
  message   String   @db.LongText
  isOpened  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminContact {
  id           String   @id @default(uuid())
  phone        String   @unique
  phonetwo     String?  @unique
  email        String   @unique
  emailtwo     String?  @unique
  address      String   @db.Text
  addresstwo   String?  @db.Text
  facebookUrl  String?  @db.Text
  linkedinUrl  String?  @db.Text
  instagramUrl String?  @db.Text
  xUrl         String?  @db.Text
  discordUrl   String?  @db.Text
  googleMapUrl String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id                                String    @id @default(uuid())
  title                             String
  description                       String    @db.LongText
  businessStrategy                  String?   @db.LongText
  visionAndGoal                     String?   @db.LongText
  operationalAndProcessOptimization String?   @db.LongText
  projectSolution                   String?   @db.LongText
  projectBusinessStrategy           String?   @db.LongText
  categoryId                        String
  category                          Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  client                            String?
  startDate                         DateTime?
  endDate                           DateTime?
  thumbnail                         String    @db.LongText
  thumbnailOptional1                String?   @db.LongText
  thumbnailOptional2                String?   @db.LongText
  createdAt                         DateTime  @default(now())
  updatedAt                         DateTime  @updatedAt
}

model Service {
  id                    String                 @id @default(uuid())
  title                 String
  description           String                 @db.LongText
  serviceOffer          String?                @db.LongText
  serviceSolution       String?                @db.LongText
  serviceOptimization   String?                @db.LongText
  categoryId            String
  category              Category               @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  thumbnail             String                 @db.LongText
  thumbnailOptional1    String?                @db.LongText
  thumbnailOptional2    String?                @db.LongText
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  serviceOfferKeyPoints ServiceOfferKeyPoint[]
}

model ServiceOfferKeyPoint {
  id           String   @id @default(uuid())
  point        String
  serviceId    String
  serviceOffer Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum DepartmentHeadStatus {
  ACTIVE
  INACTIVE
}

model DepartmentHead {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String   @unique
  designation  String
  linkedinUrl  String?  @db.Text
  facebookUrl  String?  @db.Text
  instagramUrl String?  @db.Text
  xUrl         String?  @db.Text
  password     String   @db.Text
  roleId       String
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  profilePhoto String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Employ {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String   @unique
  designation  String
  linkedinUrl  String?  @db.Text
  facebookUrl  String?  @db.Text
  instagramUrl String?  @db.Text
  xUrl         String?  @db.Text
  profilePhoto String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum TestimonialStatus {
  ACTIVE
  INACTIVE
}

model Testimonial {
  id           String            @id @default(uuid())
  name         String
  description  String            @db.LongText
  designation  String?
  rating       Int
  profilePhoto String?           @db.Text
  status       TestimonialStatus @default(ACTIVE)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model Partnership {
  id        String   @id @default(uuid())
  brandName String?
  url       String?
  logo      String?  @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum FaqStatus {
  ACTIVE
  INACTIVE
}

model Faq {
  id        String    @id @default(uuid())
  question  String
  answer    String
  status    FaqStatus @default(ACTIVE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Banner {
  id          String   @id @default(uuid())
  title       String
  subTitle    String
  description String?  @db.LongText
  sideImage1  String?  @db.LongText
  sideImage2  String?  @db.LongText
  logo        String?  @db.LongText
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AboutHome {
  id               String              @id @default(uuid())
  title            String
  description      String              @db.LongText
  numberOfProjects Int?
  numberOfClients  Int?
  sideImage1       String?             @db.LongText
  sideImage2       String?             @db.LongText
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  keyPoints        AboutHomeKeyPoint[]
}

model AboutHomeKeyPoint {
  id          String    @id @default(uuid())
  point       String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  aboutHomeId String
  aboutHome   AboutHome @relation(fields: [aboutHomeId], references: [id], onDelete: Cascade)
}

model AboutDetails {
  id          String   @id @default(uuid())
  experience  Int
  description String   @db.LongText
  vision      String   @db.LongText
  mission     String   @db.LongText
  values      String   @db.LongText
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Footer {
  id          String   @id @default(uuid())
  description String   @db.LongText
  copyright   String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TermsAndCondition {
  id          String   @id @default(uuid())
  title       String
  description String   @db.LongText
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PrivacyPolicy {
  id          String   @id @default(uuid())
  title       String
  description String   @db.LongText
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
  TEMPORARY
  VOLUNTEER
  APPRENTICESHIP
}

model JobCircular {
  id                     String           @id @default(uuid())
  jobTitle               String
  jobType                JobType
  whatYouWillDo          String           @db.LongText
  jobResponsibilities    String           @db.LongText
  experienceRequired     String           @db.LongText
  additionalRequirements String           @db.LongText
  experience             Int
  workingHours           Int
  workingDays            Int
  salary                 String
  vacancy                Int
  deadline               DateTime
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  jobApplications        JobApplication[]
}

model JobApplication {
  id               String      @id @default(uuid())
  fullName         String
  email            String
  phoneNumber      String
  address          String
  gender           String
  highestEducation String
  schoolName       String
  expectedSalary   String
  previousCompany  String?
  previousPosition String?
  resume           String      @db.LongText
  coverLetter      String?     @db.LongText
  facebookProfile  String
  linkedinProfile  String?
  githubProfile    String?
  portfolio        String?
  jobCircularId    String
  jobCircular      JobCircular @relation(fields: [jobCircularId], references: [id], onDelete: Cascade)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model SpecializedIndustry {
  id          String   @id @default(uuid())
  name        String
  icon        String   @db.LongText
  description String   @db.LongText
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Technology {
  id        String   @id @default(uuid())
  title     String   @unique
  icon      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum InvoiceType {
  NORMAL
  UPGRADE
  MAINTENANCE
}

enum PaymentMethod {
  BANK_TRANSFER
  BKASH
  NAGAD
  CASH
  CARD
}

model Client {
  id              String           @id @default(uuid())
  name            String           @unique
  email           String           @unique
  phone           String           @unique
  address         String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  projectInvoices ProjectInvoice[]
  invoices        Invoice[]
}

model ProjectInvoice {
  id        String    @id @default(uuid())
  name      String    @unique
  message   String?   @db.LongText
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  Invoice   Invoice[]
}

model Invoice {
  id         String         @id @default(uuid())
  invoiceId  String         @unique
  type       InvoiceType
  status     String         @default("DRAFT")
  clientId   String
  projectId  String
  client     Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project    ProjectInvoice @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issueDate  DateTime
  dueDate    DateTime
  subtotal   Decimal        @default(0) @db.Decimal(10, 2)
  tax        Decimal        @default(0) @db.Decimal(10, 2)
  discount   Decimal        @default(0) @db.Decimal(10, 2)
  total      Decimal        @default(0) @db.Decimal(10, 2)
  amountPaid Decimal        @default(0) @db.Decimal(10, 2)
  balanceDue Decimal        @default(0) @db.Decimal(10, 2)
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items    InvoiceItem[]
  BankInfo BankInfo?
}

model BankInfo {
  id            String        @id @default(uuid())
  bankName      String
  accountName   String
  accountNumber String
  branch        String?
  paymentMethod PaymentMethod
  invoiceId     String        @unique
  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  isDefault     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model InvoiceItem {
  id        String   @id @default(uuid())
  invoiceId String
  title     String
  total     Decimal  @db.Decimal(10, 2)
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
